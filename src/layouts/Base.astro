---
interface Props {
  title?: string
  description?: string
}
const {
  title = 'SpVgg Höhenkirchen',
  description = 'Spielvereinigung Höhenkirchen — Fußball seit 1945',
} = Astro.props

const LOGO = '/logo.png'

const navLinks = [
  { label: 'Mannschaften', href: '/mannschaften' },
  { label: 'Spielplan',    href: '/spielplan' },
  { label: 'News',         href: '/news' },
  { label: 'Verein',       href: '/verein' },
]

const currentPath = Astro.url.pathname
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />
  <title>{title === 'SpVgg Höhenkirchen' ? title : `${title} — SpVgg Höhenkirchen`}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    a { color: inherit; text-decoration: none; }

    :root {
      --color-red:     #C8102E;
      --color-black:   #111111;
      --color-surface: #1C1C1C;
      --color-border:  #2E2E2E;
      --color-text:    #EDECEA;
      --color-muted:   #ABABAB;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--color-black);
      color: var(--color-text);
      font-family: 'Barlow', sans-serif;
      font-size: 17px;
      font-weight: 400;
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* ── UTILITIES ── */
    .container { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }

    .section-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.94rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--color-muted);
      border-left: 2px solid var(--color-red);
      padding-left: 0.5rem;
      margin-bottom: 0.5rem;
    }

    .section-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      text-transform: uppercase;
      line-height: 1;
      letter-spacing: 1px;
    }
    .section-title .red { color: var(--color-red); }

    .section-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 2.5rem;
      gap: 1rem;
    }

    .link-all {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.92rem;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--color-red);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.4rem;
      white-space: nowrap;
      transition: gap 0.2s;
    }
    .link-all::after { content: "→"; }
    .link-all:hover { gap: 0.7rem; }

    .btn-primary {
      display: inline-block;
      background: var(--color-red);
      color: #fff;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.96rem;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 0.8rem 1.8rem;
      text-decoration: none;
      border-radius: 2px;
      border: none;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s;
    }
    .btn-primary:hover { background: #a50d25; transform: translateY(-1px); }

    .btn-outline {
      display: inline-block;
      background: transparent;
      color: var(--color-text);
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.96rem;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 0.8rem 1.8rem;
      text-decoration: none;
      border-radius: 2px;
      border: 2px solid var(--color-border);
      cursor: pointer;
      transition: border-color 0.2s, transform 0.15s;
    }
    .btn-outline:hover { border-color: var(--color-text); transform: translateY(-1px); }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--color-black); }
    ::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--color-muted); }
  </style>
</head>
<body>

<!-- ── NAVIGATION ── -->
<nav id="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-logo">
      <img src={LOGO} alt="SpVgg Höhenkirchen" height="38" width="38" />
      <div class="nav-logo-text">
        <span class="nav-logo-name">SpVgg Höhenkirchen</span>
        <span class="nav-logo-sub">seit 1945</span>
      </div>
    </a>

    <ul class="nav-links">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a href="/mitmachen/mitgliedschaft" class="btn-primary nav-cta">Mitglied werden</a>

    <button class="nav-burger" id="navBurger" aria-label="Menü öffnen">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="nav-mobile" id="navMobile">
    {navLinks.map(link => (
      <a href={link.href} class="nav-mobile-link">{link.label}</a>
    ))}
    <a href="/mitmachen/mitgliedschaft" class="btn-primary" style="margin-top:0.5rem;text-align:center;">Mitglied werden</a>
  </div>
</nav>

<main>
  <slot />
</main>

<!-- ── FOOTER ── -->
<footer id="footer">
  <div class="container footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-logo-wrap">
          <img src={LOGO} alt="SpVgg Höhenkirchen" height="56" width="56" />
          <div>
            <div class="footer-logo-name">SpVgg Höhenkirchen</div>
            <div class="footer-logo-sub">Spielvereinigung seit 1945</div>
          </div>
        </div>
        <p class="footer-desc">
          Fußball für die ganze Familie — von den Bambini bis zu den Senioren.<br />
          Teil der <a href="https://www.spvgg-hoehenkirchen.de" target="_blank" rel="noopener">SpVgg Höhenkirchen e.V.</a>
        </p>
      </div>

      <div class="footer-col">
        <div class="footer-col-title">Fußball</div>
        <ul class="footer-links">
          <li><a href="/mannschaften">Mannschaften</a></li>
          <li><a href="/spielplan">Spielplan</a></li>
          <li><a href="/news">News & Berichte</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <div class="footer-col-title">Verein</div>
        <ul class="footer-links">
          <li><a href="/verein/ueber-uns">Geschichte & Chronik</a></li>
          <li><a href="/verein/ansprechpartner">Ansprechpartner</a></li>
          <li><a href="/verein/training">Trainingszeiten</a></li>
          <li><a href="/verein/anfahrt">Anfahrt</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <div class="footer-col-title">Mitmachen</div>
        <ul class="footer-links">
          <li><a href="/mitmachen/mitgliedschaft">Mitglied werden</a></li>
          <li><a href="/mitmachen/jugend">Jugend anmelden</a></li>
          <li><a href="/sponsoren">Sponsoring</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">© 2026 SpVgg Höhenkirchen e.V. — Abteilung Fußball</span>
      <ul class="footer-legal">
        <li><a href="/impressum">Impressum</a></li>
        <li><a href="/datenschutz">Datenschutz</a></li>
      </ul>
    </div>
  </div>
</footer>

<style>
  /* ── NAV ── */
  #nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(17,17,17,0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 2px solid var(--color-red);
  }
  .nav-inner {
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .nav-logo img { display: block; }
  .nav-logo-text { line-height: 1.2; }
  .nav-logo-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-text);
  }
  .nav-logo-sub {
    font-size: 0.90rem;
    letter-spacing: 1px;
    color: var(--color-red);
    text-transform: uppercase;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
  }
  .nav-links {
    display: flex;
    gap: 0.1rem;
    list-style: none;
    flex: 1;
    justify-content: center;
  }
  .nav-link {
    display: block;
    padding: 0.4rem 0.9rem;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    border-radius: 2px;
    transition: color 0.2s;
  }
  .nav-link:hover, .nav-link.active { color: var(--color-text); }
  .nav-link.active { color: var(--color-red); }
  .nav-cta { flex-shrink: 0; font-size: 0.8rem; padding: 0.55rem 1.2rem; }

  .nav-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav-burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    border-radius: 1px;
    transition: 0.2s;
  }

  .nav-mobile {
    display: none;
    flex-direction: column;
    padding: 1rem 1.5rem 1.5rem;
    border-top: 1px solid var(--color-border);
    gap: 0.2rem;
  }
  .nav-mobile.open { display: flex; }
  .nav-mobile-link {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
    transition: color 0.2s;
  }
  .nav-mobile-link:hover { color: var(--color-text); }

  @media (max-width: 860px) {
    .nav-links, .nav-cta { display: none; }
    .nav-burger { display: flex; }
  }

  /* ── FOOTER ── */
  #footer {
    background: #0d0d0d;
    border-top: 2px solid var(--color-red);
    padding: 3.5rem 0 1.5rem;
    margin-top: 0;
  }
  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
  }
  .footer-logo-wrap {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 1rem;
  }
  .footer-logo-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .footer-logo-sub {
    font-size: 0.7rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-red);
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
  }
  .footer-desc {
    font-size: 0.95rem;
    color: var(--color-muted);
    line-height: 1.7;
  }
  .footer-desc a { color: var(--color-muted); transition: color 0.2s; }
  .footer-desc a:hover { color: var(--color-red); }
  .footer-col-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 0.90rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-red);
    display: inline-block;
  }
  .footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.45rem; }
  .footer-links a {
    font-size: 0.95rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--color-red); }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .footer-copy { font-size: 0.90rem; color: #444; }
  .footer-legal { display: flex; gap: 1.5rem; list-style: none; }
  .footer-legal a { font-size: 0.90rem; color: #444; text-decoration: none; transition: color 0.2s; }
  .footer-legal a:hover { color: var(--color-muted); }

  @media (max-width: 960px) {
    .footer-top { grid-template-columns: 1fr 1fr; gap: 2rem; }
  }
  @media (max-width: 600px) {
    .footer-top { grid-template-columns: 1fr; }
  }
</style>

<script>
  const burger = document.getElementById('navBurger')
  const mobile = document.getElementById('navMobile')
  burger?.addEventListener('click', () => mobile?.classList.toggle('open'))
</script>

</body>
</html>
