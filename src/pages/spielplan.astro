---
import Base from '../layouts/Base.astro'
import { readSingleton } from '../lib/content'

const data = readSingleton('spielplan')
const alleSpiele    = data?.spiele ?? []
const naechsteSpiele = alleSpiele.filter(s => s.status === 'kommend')
const ergebnisse     = alleSpiele.filter(s => s.status === 'abgeschlossen')
const saison = data?.saison ?? ''
const bfvUrl = data?.fussball_de_url ?? ''

function ergebnisBadge(e: typeof ergebnisse[0]) {
  const spvggHeim = e.heim.includes('Höhenkirchen')
  const spvggTore = spvggHeim ? (e.heimTor ?? 0) : (e.gastTor ?? 0)
  const gegTore   = spvggHeim ? (e.gastTor ?? 0) : (e.heimTor ?? 0)
  if (spvggTore > gegTore) return 'win'
  if (spvggTore === gegTore) return 'draw'
  return 'loss'
}

const badgeText = { win: 'Sieg', draw: 'Unent.', loss: 'Niederlage' }
---

<Base title="Spielplan" description="Spielplan und Ergebnisse der SpVgg Höhenkirchen.">

  <div class="page-hero">
    <div class="container">
      {saison && <p class="section-eyebrow">Saison {saison}</p>}
      <h1 class="page-title">Spielplan & <span>Ergebnisse</span></h1>
      <p class="page-sub">
        Aktuelle Ergebnisse und kommende Spiele der 1. Mannschaft.
        Vollständige Tabellen und alle Altersklassen auf bfv.de.
      </p>
    </div>
  </div>

  <section class="spielplan-section">
    <div class="container spielplan-grid">

      <!-- Nächste Spiele -->
      <div>
        <div class="block-header">
          <div>
            <p class="section-eyebrow">Kommend</p>
            <h2 class="section-title">Nächste <span class="red">Spiele</span></h2>
          </div>
        </div>

        <div class="spiel-list">
          {naechsteSpiele.map(s => (
            <div class="spiel-card spiel-card--upcoming">
              <div class="spiel-top">
                <span class="spiel-liga">{s.liga}</span>
                {s.uhrzeit && <span class="spiel-badge spiel-badge--upcoming">Anpfiff {s.uhrzeit} Uhr</span>}
                <span class="spiel-datum">{s.datum}</span>
              </div>
              <div class="spiel-teams">
                <span class:list={['spiel-team', { 'spiel-team--spvgg': s.heim.includes('Höhenkirchen') }]}>
                  {s.heim}
                </span>
                <span class="spiel-vs">vs.</span>
                <span class:list={['spiel-team spiel-team--away', { 'spiel-team--spvgg': s.gast.includes('Höhenkirchen') }]}>
                  {s.gast}
                </span>
              </div>
              {s.ort && <div class="spiel-ort">📍 {s.ort}</div>}
            </div>
          ))}
        </div>
      </div>

      <!-- Ergebnisse -->
      <div>
        <div class="block-header">
          <div>
            <p class="section-eyebrow">Abgeschlossen</p>
            <h2 class="section-title">Letzte <span class="red">Ergebnisse</span></h2>
          </div>
        </div>

        <div class="spiel-list">
          {ergebnisse.map(e => {
            const badge = ergebnisBadge(e)
            return (
              <div class={`spiel-card spiel-card--${badge}`}>
                <div class="spiel-top">
                  <span class="spiel-liga">{e.liga}</span>
                  <span class={`spiel-badge spiel-badge--${badge}`}>{badgeText[badge]}</span>
                  <span class="spiel-datum">{e.datum}</span>
                </div>
                <div class="spiel-teams">
                  <span class:list={['spiel-team', { 'spiel-team--spvgg': e.heim.includes('Höhenkirchen') }]}>
                    {e.heim}
                  </span>
                  <span class={`spiel-score spiel-score--${badge}`}>
                    {e.heimTor} : {e.gastTor}
                  </span>
                  <span class:list={['spiel-team spiel-team--away', { 'spiel-team--spvgg': e.gast.includes('Höhenkirchen') }]}>
                    {e.gast}
                  </span>
                </div>
              </div>
            )
          })}
        </div>
      </div>

    </div>

    {bfvUrl && (
      <div class="bfv-cta-wrap">
        <a href={bfvUrl} target="_blank" rel="noopener noreferrer" class="bfv-cta">
          <div class="bfv-cta-inner">
            <div class="bfv-cta-text">
              <span class="bfv-cta-label">Alle Mannschaften</span>
              <span class="bfv-cta-title">Vollständige Spielpläne & Tabellen</span>
            </div>
            <span class="bfv-cta-btn">Auf bfv.de öffnen →</span>
          </div>
        </a>
      </div>
    )}

  </section>

</Base>

<style>
  .page-hero {
    background: var(--color-black);
    border-bottom: 1px solid var(--color-border);
    padding: 7rem 0 3rem;
  }
  .page-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(3rem, 8vw, 6rem);
    text-transform: uppercase;
    line-height: 1;
    letter-spacing: 1px;
    margin-bottom: 0.75rem;
  }
  .page-title span { color: var(--color-red); }
  .page-sub { font-size: 1rem; font-weight: 300; color: var(--color-muted); max-width: 560px; }
  .page-sub a { color: var(--color-red); }

  .spielplan-section { padding: 3.5rem 0 5rem; background: var(--color-black); }
  .spielplan-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: flex-start;
  }

  .block-header { margin-bottom: 1.5rem; }

  /* Cards */
  .spiel-list { display: flex; flex-direction: column; gap: 1px; }
  .spiel-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left-width: 3px;
    border-radius: 2px;
    padding: 1rem 1.25rem;
    transition: border-color 0.15s;
  }
  .spiel-card:hover { border-color: var(--color-muted); border-left-color: inherit; }
  .spiel-card--win      { border-left-color: var(--color-red); }
  .spiel-card--draw     { border-left-color: var(--color-muted); }
  .spiel-card--loss     { border-left-color: #333; }
  .spiel-card--upcoming { border-left-color: #3a6ea5; }

  .spiel-top {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .spiel-liga {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.90rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .spiel-datum {
    font-size: 0.94rem;
    color: var(--color-muted);
    margin-left: auto;
  }
  .spiel-badge {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.6rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 2px;
  }
  .spiel-badge--win      { background: rgba(200,16,46,0.15); color: var(--color-red); }
  .spiel-badge--draw     { background: rgba(136,136,136,0.12); color: var(--color-muted); }
  .spiel-badge--loss     { background: rgba(255,255,255,0.05); color: #555; }
  .spiel-badge--upcoming { background: rgba(58,110,165,0.15); color: #3a6ea5; }

  .spiel-teams {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-content: space-between;
  }
  .spiel-team {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.92rem;
    text-transform: uppercase;
    flex: 1;
    line-height: 1.3;
    color: var(--color-muted);
  }
  .spiel-team--away { text-align: right; }
  .spiel-team--spvgg { color: var(--color-text); font-weight: 800; }
  .spiel-score {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 1.7rem;
    line-height: 1;
    letter-spacing: 2px;
    white-space: nowrap;
    color: var(--color-text);
    background: var(--color-black);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 0.25rem 0.75rem;
    flex-shrink: 0;
  }
  .spiel-score--win  { color: var(--color-red); }
  .spiel-score--draw { color: var(--color-muted); }
  .spiel-vs {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-border);
    flex-shrink: 0;
  }
  .spiel-ort {
    font-size: 0.86rem;
    color: var(--color-muted);
    margin-top: 0.5rem;
  }

  .bfv-cta-wrap {
    padding: 3rem 0 5rem;
  }
  .bfv-cta {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-red);
    border-radius: 3px;
    transition: border-color 0.2s, background 0.2s;
  }
  .bfv-cta:hover {
    border-color: var(--color-red);
    background: #1f1414;
  }
  .bfv-cta-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .bfv-cta-text {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .bfv-cta-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-red);
  }
  .bfv-cta-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    text-transform: uppercase;
    letter-spacing: 1px;
    line-height: 1;
    color: var(--color-text);
  }
  .bfv-cta-btn {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #fff;
    background: var(--color-red);
    padding: 0.85rem 2rem;
    border-radius: 2px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }
  .bfv-cta:hover .bfv-cta-btn { opacity: 0.85; }

  @media (max-width: 800px) {
    .bfv-cta-inner { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
    .bfv-cta-btn { align-self: stretch; text-align: center; }
    .spielplan-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
