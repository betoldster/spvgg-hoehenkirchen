---
import Base from '../../layouts/Base.astro'
import VereinNav from '../../components/VereinNav.astro'
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../../keystatic.config'

const reader = createReader(process.cwd(), keystaticConfig)
const data = await reader.singletons.anfahrt.read()

const adresse = {
  name:    data?.name    ?? 'Sportanlage SpVgg Höhenkirchen',
  strasse: data?.strasse ?? 'Sportplatzstraße 1',
  ort:     data?.ort     ?? '85635 Höhenkirchen-Siegertsbrunn',
}
const anfahrt = data?.optionen ?? []

const mapsQuery = encodeURIComponent(`${adresse.strasse}, ${adresse.ort}`)
const mapsEmbedUrl = `https://maps.google.com/maps?q=${mapsQuery}&output=embed`
---

<Base title="Anfahrt" description="So findest du die Sportanlage der SpVgg Höhenkirchen.">

  <div class="page-hero">
    <div class="container">
      <p class="section-eyebrow">Lage</p>
      <h1 class="page-title">An<span>fahrt</span></h1>
      <p class="page-sub">So findest du uns — mit Auto, Bus oder Fahrrad.</p>
    </div>
  </div>

  <VereinNav active="/verein/anfahrt" />

  <section class="anfahrt-section">
    <div class="container">

      <div class="anfahrt-grid">

        <!-- Karte -->
        <div class="map-wrap">
          <iframe
            src={mapsEmbedUrl}
            width="100%"
            height="420"
            style="border:0; border-radius: 3px; filter: grayscale(0.3) contrast(1.1);"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Karte SpVgg Höhenkirchen"
          ></iframe>
        </div>

        <!-- Info -->
        <div class="info-col">

          <div class="adresse-card">
            <div class="adresse-icon">📍</div>
            <div>
              <div class="adresse-name">{adresse.name}</div>
              <div class="adresse-zeile">{adresse.strasse}</div>
              <div class="adresse-zeile">{adresse.ort}</div>
              <div class="adresse-actions">
                <a
                  href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(adresse.strasse + ', ' + adresse.ort)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-primary"
                >
                  In Google Maps öffnen →
                </a>
              </div>
            </div>
          </div>

          <div class="anfahrt-list">
            {anfahrt.map(a => (
              <div class="anfahrt-item">
                <div class="anfahrt-icon">{a.icon}</div>
                <div>
                  <div class="anfahrt-titel">{a.titel}</div>
                  <p class="anfahrt-text">{a.text}</p>
                </div>
              </div>
            ))}
          </div>

        </div>
      </div>

    </div>
  </section>

</Base>

<style>
  .page-hero {
    background: var(--color-black);
    border-bottom: 1px solid var(--color-border);
    padding: 7rem 0 3rem;
  }
  .page-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(3rem, 8vw, 6rem);
    text-transform: uppercase;
    line-height: 1;
    letter-spacing: 1px;
    margin-bottom: 0.75rem;
  }
  .page-title span { color: var(--color-red); }
  .page-sub { font-size: 1rem; font-weight: 300; color: var(--color-muted); }

  .anfahrt-section { padding: 4rem 0 5rem; background: var(--color-black); }
  .anfahrt-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 2.5rem;
    align-items: start;
  }

  .map-wrap {
    border: 1px solid var(--color-border);
    border-radius: 3px;
    overflow: hidden;
  }

  .info-col { display: flex; flex-direction: column; gap: 1.5rem; }

  .adresse-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-red);
    border-radius: 3px;
    padding: 1.5rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .adresse-icon { font-size: 1.5rem; flex-shrink: 0; }
  .adresse-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.3rem;
  }
  .adresse-zeile { font-size: 0.96rem; color: var(--color-muted); line-height: 1.6; }
  .adresse-actions { margin-top: 1rem; }

  .anfahrt-list { display: flex; flex-direction: column; gap: 1rem; }
  .anfahrt-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 1.25rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .anfahrt-icon { font-size: 1.4rem; flex-shrink: 0; }
  .anfahrt-titel {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.4rem;
  }
  .anfahrt-text {
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--color-muted);
    line-height: 1.65;
  }

  @media (max-width: 860px) {
    .anfahrt-grid { grid-template-columns: 1fr; }
  }
</style>
